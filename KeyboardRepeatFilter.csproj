<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net48</TargetFramework>
    <PlatformTarget>AnyCPU</PlatformTarget>
    <LangVersion>9.0</LangVersion>
    <Optimize>true</Optimize>
    <Company>Luc Duguay</Company>
    <Description>G915-Stutter-Fix</Description>
    <Copyright>MIT License</Copyright>
    <RepositoryUrl>https://github.com/lucduguaysita/G915-Stutter-Fix</RepositoryUrl>
    <!-- Single source of truth for the version: AssemblyVersion, FileVersion, and
         InformationalVersion are generated from this by the SDK (GenerateAssemblyInfo,
         default on), so bumping it here flows to the built exe automatically. -->
    <Version>3.0.2</Version>
    <Title>G915-Stutter-Fix</Title>
    <AssemblyTitle>G915-Stutter-Fix</AssemblyTitle>
    <ApplicationIcon>app.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="KeyboardHeatmap\**" />
    <EmbeddedResource Remove="KeyboardHeatmap\**" />
    <None Remove="KeyboardHeatmap\**" />
  </ItemGroup>
  <ItemGroup>
    <None Remove="app.ico" />
    <None Remove="src\app.ico" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="app.ico" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="System.Windows.Forms" />
  </ItemGroup>
  <!-- Build KeyboardHeatmap first (without referencing its assembly) so the
       post-build copy below always has a fresh exe to place next to the app. -->
  <ItemGroup>
    <ProjectReference Include="KeyboardHeatmap\KeyboardHeatmap.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
  </ItemGroup>
  <ItemGroup>
    <Compile Update="src\VirtualKeys.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>VirtualKeys.resx</DependentUpon>
    </Compile>
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Update="src\VirtualKeys.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>VirtualKeys.Designer.cs</LastGenOutput>
      <CustomToolNamespace>KeyboardRepeatFilter</CustomToolNamespace>
      <LogicalName>KeyboardRepeatFilter.VirtualKeys.resources</LogicalName>
    </EmbeddedResource>
  </ItemGroup>
  <ItemGroup>
    <None Update="src\config.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>config.json</Link>
    </None>
    <None Update="src\gaming.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>gaming.json</Link>
    </None>
    <None Update="src\WoW.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>WoW.json</Link>
    </None>
  </ItemGroup>
  <!-- Copy KeyboardHeatmap.exe next to the app's build output (Debug and
       Release) so "Generate report" works when running/testing from VS. -->
  <Target Name="CopyHeatmapToOutput" AfterTargets="Build">
    <PropertyGroup>
      <HeatmapExe>$(MSBuildProjectDirectory)\KeyboardHeatmap\bin\$(Configuration)\KeyboardHeatmap.exe</HeatmapExe>
    </PropertyGroup>
    <Copy SourceFiles="$(HeatmapExe)" DestinationFolder="$(TargetDir)" SkipUnchangedFiles="true" Condition="Exists('$(HeatmapExe)')" />
  </Target>
  <Target Name="RefreshReleasesFolder" AfterTargets="Build" Condition="'$(Configuration)' == 'Release'">
    <PropertyGroup>
      <ReleasesDir>$(MSBuildProjectDirectory)\releases\</ReleasesDir>
    </PropertyGroup>
    <RemoveDir Directories="$(ReleasesDir)" />
    <MakeDir Directories="$(ReleasesDir)" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(ReleasesDir)" />
    <Copy SourceFiles="$(TargetDir)Newtonsoft.Json.dll" DestinationFolder="$(ReleasesDir)" Condition="Exists('$(TargetDir)Newtonsoft.Json.dll')" />
    <Copy SourceFiles="$(TargetDir)config.json" DestinationFolder="$(ReleasesDir)" Condition="Exists('$(TargetDir)config.json')" />
    <Copy SourceFiles="$(TargetDir)gaming.json" DestinationFolder="$(ReleasesDir)" Condition="Exists('$(TargetDir)gaming.json')" />
    <Copy SourceFiles="$(TargetDir)WoW.json" DestinationFolder="$(ReleasesDir)" Condition="Exists('$(TargetDir)WoW.json')" />
    <Copy SourceFiles="$(MSBuildProjectDirectory)\KeyboardHeatmap\bin\Release\KeyboardHeatmap.exe" DestinationFolder="$(ReleasesDir)" Condition="Exists('$(MSBuildProjectDirectory)\KeyboardHeatmap\bin\Release\KeyboardHeatmap.exe')" />
  </Target>
</Project>
